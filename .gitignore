# Dependencies
node_modules/

# Build output (regenerated by npm run build)
dist/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# GitHub / CI internal files (architecture docs, copilot instructions, etc.)
.github/

# ESLint config (optional tooling, not needed in repo)
.eslintignore

# Root config (dev artifact, not part of the library)
type-bridge.config.ts

# Smoke-test generated output (regenerated on demand)
smoke-test/frontend/src/types/generated/

# TypeScript build info cache
*.tsbuildinfo
